{
  "expo": {
    "name": "Capshion",
    "slug": "capshion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "capshion",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#05050A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#05050A",
      "bundleIdentifier": "com.furkan.capshion",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Capshion requires camera access to analyze your photos and generate premium, tailored social media captions.",
        "NSPhotoLibraryUsageDescription": "Capshion requires photo library access to let you select images for professional caption generation.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "backgroundColor": "#05050A",
      "package": "com.furkan.capshion",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#05050A",
        "foregroundImage": "./assets/images/logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#05050A"
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1ccd1617-9d62-4273-a533-f71e2ec93728"
      }
    }
  }
}
